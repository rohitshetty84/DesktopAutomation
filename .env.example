# ── Azure OpenAI (o4-mini + gpt-4o) ──────────────────────────────────────────
# Same endpoint/key for both; the deployment name selects the model.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here

# General / vision deployment (used by the verifier + vision self-heal)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Reasoning deployment (o4-mini) — used by the planner + self-healer.
# o4-mini needs a newer api-version than the general models.
AZURE_REASONING_DEPLOYMENT=o4-mini
AZURE_REASONING_API_VERSION=2024-12-01-preview

# ── Azure AI Foundry (Claude Haiku) — STUBBED ────────────────────────────────
# Haiku is NOT reachable through the openai SDK above. When you enable the
# Foundry adapter (src/desktoptest/model/azure_foundry_adapter.py), set:
# AZURE_FOUNDRY_ENDPOINT=https://YOUR-FOUNDRY.services.ai.azure.com
# AZURE_FOUNDRY_API_KEY=your-foundry-key-here
# AZURE_FOUNDRY_DEPLOYMENT=claude-haiku-4-5

# ── SAP GUI ──────────────────────────────────────────────────────────────────
# Scripting must be enabled: server profile sapgui/user_scripting=TRUE
# and client-side under Options -> Accessibility & Scripting -> Scripting.
#
# SAP_CONNECTION / SAP_CLIENT are used by SapSession.launch() to open a FRESH
# SAP GUI session per test run via sapshcut.exe (SSO login — no password
# needed), mirroring:
#   sapshcut.exe -system=<SAP_CONNECTION> -client=<SAP_CLIENT>
# The session is closed again automatically once the run finishes.
SAP_CONNECTION=EQ5
SAP_CLIENT=100

# Path to sapshcut.exe — override if your install isn't at the default location.
# SAP_SHCUT_PATH=C:\Program Files (x86)\SAP\FrontEnd\SAPgui\sapshcut.exe

# Seconds to wait for SAP GUI to open + SSO login to complete before giving up.
# SAP_LAUNCH_TIMEOUT=60

# SAP_USER / SAP_PASSWORD are NOT used — login is via SSO through sapshcut.exe.
# Only relevant if you swap in a non-SSO login flow yourself.

# Run without a real SAP GUI attached (development on mac/Linux, or smoke-testing
# the wiring on Windows without launching SAP): true|false
SAP_DRY_RUN=false

# ── Dashboard server ──────────────────────────────────────────────────────────
# Port for the local web dashboard (studio/server.py, launched via run_server.sh).
# Defaults to 8501 (not 8000) so it won't collide if you also run the Playwright
# AI Studio locally on the same machine.
PORT=8501
